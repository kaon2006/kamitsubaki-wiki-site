---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { buildProjectDisplayData, getLocalizedSite } from '../../../lib/homeData.mjs';
import { buildLocaleLinks, defaultLocale, supportedLocales } from '../../../lib/i18n.mjs';
import { buildProjectMetadata } from '../../../lib/metadata.mjs';

export async function getStaticPaths() {
  const projectEntries = await getCollection('projects');

  return projectEntries.map((entry) => {
    const parts = entry.id.split('/');
    const entryLocale = parts.pop();
    const idPath = parts.join('/');

    return {
      params: {
        locale: entryLocale,
        id: idPath,
      },
      props: { entry },
    };
  });
}

const { locale, id } = Astro.params;
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const localeCode = locale as 'zh' | 'ja' | 'en';
const siteEntries = await getCollection('site');
const homeContent = getLocalizedSite(siteEntries, localeCode, defaultLocale);
const project = buildProjectDisplayData(entry, localeCode);
const currentPath = `/projects/${id}`;
const localeLinks = buildLocaleLinks(homeContent, localeCode, currentPath);
const alternates = supportedLocales.map((localeCode) => ({
  locale: localeCode,
  href: `/${localeCode}/projects/${id}`,
}));
const metadata = buildProjectMetadata({
  data: project,
  body: entry.body,
  locale: localeCode,
  id,
});
const hasArticleBody = Boolean(entry.body?.trim());
const hasTableOfContents = headings.some((heading) => heading.depth === 2 || heading.depth === 3);

const labels = {
  zh: {
    back: '返回首页',
    eyebrow: '项目条目',
    contents: '目录',
    category: '分类',
  },
  ja: {
    back: 'ホームへ戻る',
    eyebrow: 'プロジェクト記事',
    contents: '目次',
    category: '分類',
  },
  en: {
    back: 'Back to home',
    eyebrow: 'Project Article',
    contents: 'Contents',
    category: 'Category',
  },
}[localeCode];
---

<BaseLayout lang={localeCode} alternates={alternates} title={`${project.title} - Kamitsubaki Studio Fan Wiki`} metadata={metadata}>
  <SiteNav navItems={homeContent.navItems} localeLinks={localeLinks} brandLines={homeContent.hero.brandLines} compact homeHref={`/${localeCode}/`} />

  <div class="fixed left-0 top-0 z-[60] h-px w-full origin-left bg-white/70" data-reading-progress></div>

  <main class="mx-auto max-w-[92rem] px-4 pb-12 pt-24 sm:px-6 sm:pt-28 lg:pt-28">
    <div class="grid gap-8 border-b border-white/10 pb-8 sm:gap-10 sm:pb-10 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <div class="min-w-0">
        <a href={`/${localeCode}/#projects`} class="text-[9px] font-mono uppercase tracking-[0.22em] text-white/38 transition-colors hover:text-white">
          {labels.back}
        </a>
        <p class="mt-5 text-[9px] font-mono uppercase tracking-[0.24em] text-white/32">{labels.eyebrow}</p>
        <h1 class="wiki-page-title mt-3 max-w-4xl font-serif text-[2rem] font-semibold tracking-[0.06em] text-white sm:text-5xl">
          {project.title}
        </h1>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-[10px] tracking-[0.14em] text-white/42 sm:text-[11px]">
          <span>{project.kind}</span>
          <span class="hidden h-px w-8 bg-white/15 sm:block"></span>
          <span>{labels.category}: {project.categoryTitle}</span>
        </div>
        {project.description && (
          <p class="mt-6 max-w-3xl text-sm leading-7 text-white/62 sm:text-[15px] sm:leading-8">
            {project.description}
          </p>
        )}
      </div>

      <aside class="rounded-md border border-white/10 bg-white/[0.03] p-5 sm:p-6">
        <p class="text-[9px] font-mono uppercase tracking-[0.2em] text-white/35">{project.categoryTitle}</p>
        <p class="mt-2 text-lg font-medium text-white/84">{project.kind}</p>
        <p class="mt-5 break-all text-[11px] leading-6 text-white/38">src/content/projects/{id}/{localeCode}.md</p>
      </aside>
    </div>

    <div class:list={[
      'mt-8 grid gap-8 lg:mt-10 lg:grid-cols-12',
      hasArticleBody ? '' : 'lg:grid-cols-1',
    ]}>
      {hasTableOfContents && (
        <aside class="hidden lg:col-span-2 lg:block">
          <TableOfContents headings={headings} title={labels.contents} />
        </aside>
      )}

      {hasArticleBody && (
        <article class:list={[
          'wiki-prose prose prose-invert min-w-0 max-w-none',
          hasTableOfContents ? 'lg:col-span-8' : 'lg:col-span-10 lg:col-start-2',
        ]}>
          {hasTableOfContents && (
            <details class="wiki-mobile-toc mb-8 rounded-lg border border-white/10 bg-white/[0.03] p-4 lg:hidden">
              <summary class="cursor-pointer text-[11px] font-mono uppercase tracking-[0.24em] text-white/65">
                {labels.contents}
              </summary>
              <div class="mt-4 border-t border-white/10 pt-4">
                <TableOfContents headings={headings} title={labels.contents} />
              </div>
            </details>
          )}

          <Content />
        </article>
      )}
    </div>
  </main>

  <SiteFooter footer={homeContent.footer} />
</BaseLayout>
