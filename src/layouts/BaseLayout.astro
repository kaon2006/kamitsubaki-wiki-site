---
import { getCollection } from 'astro:content';
import AiChatWidget from '../components/AiChatWidget.astro';
import SiteIntro from '../components/SiteIntro.astro';
import SocialContactWidget from '../components/SocialContactWidget.astro';
import { getLocalizedSiteName } from '../lib/i18n.mjs';
import '../styles/global.css';
import '../styles/mediaSwitcher.css';

type PageMetadata = {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
  keywords?: string[];
  noindex?: boolean;
};

const {
  title = 'Kamitsubaki Studio Fan Wiki',
  lang = 'zh',
  alternates = [],
  metadata = {},
} = Astro.props as {
  title?: string;
  lang?: string;
  alternates?: {
    locale: string;
    href: string;
  }[];
  metadata?: PageMetadata;
};

const localizedSiteName = getLocalizedSiteName(lang);
const siteOrigin = (import.meta.env.PUBLIC_SITE_URL || Astro.site?.origin || 'https://kamitsubaki.wiki').replace(/\/$/, '');
const requestedPageTitle = metadata.title || title;
const isLocalizedHome = new RegExp(`^/${lang}/?$`).test(Astro.url.pathname);
const pageTitle = isLocalizedHome
  ? localizedSiteName
  : requestedPageTitle.replace(/Kamitsubaki Studio Fan Wiki$/i, localizedSiteName);
const pageDescription = metadata.description || 'KAMITSUBAKI STUDIO 非官方粉丝百科。';
const pageType = metadata.type || 'website';
const canonicalPath = metadata.canonicalPath || Astro.url.pathname;
const canonicalUrl = siteOrigin ? `${siteOrigin}${canonicalPath}` : canonicalPath;
const pageImage = metadata.image;
const pageImageUrl = pageImage && siteOrigin && pageImage.startsWith('/') ? `${siteOrigin}${pageImage}` : pageImage;
const robots = metadata.noindex ? 'noindex, nofollow' : 'index, follow';
const siteEntries = await getCollection('site');
const defaultSiteEntry = siteEntries.find((entry) => entry.data.locale === 'zh');
const siteEntry = siteEntries.find((entry) => entry.data.locale === lang) ?? defaultSiteEntry;
const aiChatCopy = siteEntry?.data.aiChat;
const socialContactCopy = siteEntry?.data.socialContact;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <script is:inline define:vars={{ isLocalizedHome }}>
      (() => {
        const storageKey = 'kamitsubaki-theme';
        let theme = 'dark';

        try {
          const savedTheme = window.localStorage.getItem(storageKey);
          if (savedTheme === 'light' || savedTheme === 'dark') theme = savedTheme;
        } catch {
          // Storage may be unavailable in privacy-restricted browsing contexts.
        }

        document.documentElement.dataset.theme = theme;
        if (isLocalizedHome) document.documentElement.classList.add('site-intro-enabled');
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/brand/kamitsubakiwiki-square.svg" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={robots} />
    {metadata.keywords?.length && <meta name="keywords" content={metadata.keywords.join(', ')} />}
    <link rel="canonical" href={canonicalUrl} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="/zh/" />
    {isLocalizedHome && (
      <>
        <link rel="preload" href="/brand/main-logo-dark.svg" as="image" type="image/svg+xml" />
        <link rel="preload" href="/brand/main-logo-light.svg" as="image" type="image/svg+xml" />
      </>
    )}
    <meta property="og:site_name" content={localizedSiteName} />
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    {pageImageUrl && <meta property="og:image" content={pageImageUrl} />}
    <meta name="twitter:card" content={pageImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {pageImageUrl && <meta name="twitter:image" content={pageImageUrl} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;700&family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+SC:wght@400;500;600;700&family=Shippori+Mincho:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased font-sans selection:bg-white selection:text-black" id="body-wrap">
    {isLocalizedHome && <SiteIntro />}

    <div class="noise-bg"></div>
    <div class="cursor-dot hidden md:block" id="cursor"></div>

    <slot />
    {socialContactCopy && <SocialContactWidget copy={socialContactCopy} />}
    {aiChatCopy && <AiChatWidget lang={lang} copy={aiChatCopy} />}

    <script>
      import '../scripts/themeToggle.js';
      import '../scripts/siteInteractions.js';
      import '../scripts/mediaSwitcher.js';
    </script>
  </body>
</html>
