---
type SocialContactItem = {
  label: string;
  href: string;
  handle?: string;
  description?: string;
  icon?: string;
  enabled?: boolean;
  featured?: boolean;
};

type SocialContactCopy = {
  enabled?: boolean;
  eyebrow: string;
  title: string;
  buttonLabel: string;
  closeLabel: string;
  helper?: string;
  maxVisible?: number;
  items: SocialContactItem[];
};

const { copy } = Astro.props as { copy: SocialContactCopy };
const iconPaths: Record<string, string[]> = {
  bilibili: [
    'M7 4 10 7M17 4 14 7',
    'M6.5 7.5h11A3.5 3.5 0 0 1 21 11v4.5A3.5 3.5 0 0 1 17.5 19h-11A3.5 3.5 0 0 1 3 15.5V11a3.5 3.5 0 0 1 3.5-3.5Z',
    'M8.5 12.5v1.2M15.5 12.5v1.2M9 16h6',
  ],
  discord: [
    'M8.5 8.5c2.3-.7 4.7-.7 7 0M8 17c-1.4-.4-2.7-1-3.8-1.8.2-3.4 1.1-6.1 2.7-8.2 1.1-.5 2.2-.8 3.4-1l.5 1M16 17c1.4-.4 2.7-1 3.8-1.8-.2-3.4-1.1-6.1-2.7-8.2-1.1-.5-2.2-.8-3.4-1l-.5 1',
    'M9.5 13h.01M14.5 13h.01M9 16c2 1 4 1 6 0',
  ],
  github: [
    'M12 2.8a9.2 9.2 0 0 0-2.9 17.9c.46.08.62-.2.62-.43v-1.6c-2.55.55-3.08-1.08-3.08-1.08-.42-1.05-1.03-1.33-1.03-1.33-.84-.57.07-.56.07-.56.93.07 1.42.96 1.42.96.82 1.4 2.16 1 2.68.76.08-.6.32-1 .59-1.24-2.04-.23-4.18-1.02-4.18-4.54 0-1 .36-1.83.95-2.47-.1-.23-.41-1.17.09-2.44 0 0 .78-.25 2.54.95A8.8 8.8 0 0 1 12 7.37c.76 0 1.52.1 2.24.3 1.76-1.2 2.54-.95 2.54-.95.5 1.27.19 2.21.09 2.44.6.64.95 1.46.95 2.47 0 3.53-2.15 4.31-4.2 4.54.33.28.63.84.63 1.69v2.51c0 .24.16.52.63.43A9.2 9.2 0 0 0 12 2.8Z',
  ],
  mail: ['M4 6.5h16v11H4z', 'm4 7 8 6 8-6'],
  qq: ['M12 3.5c-2.7 0-4.8 2.6-4.8 6.1 0 1.4-.5 2.7-1.4 3.8.6.2 1.3.3 2 .3-.5 1.1-1.2 2-2.1 2.7 1.3.2 2.7 0 4-.5.7.4 1.5.6 2.3.6s1.6-.2 2.3-.6c1.3.5 2.7.7 4 .5-.9-.7-1.6-1.6-2.1-2.7.7 0 1.4-.1 2-.3-.9-1.1-1.4-2.4-1.4-3.8 0-3.5-2.1-6.1-4.8-6.1Z', 'M9.3 10.2h.01M14.7 10.2h.01M9.5 14.4c1.5.8 3.5.8 5 0'],
  telegram: ['M21 4 3.8 10.9c-.8.3-.8 1.4.1 1.6l4.2 1.2 1.6 5c.3.8 1.4.9 1.8.2l2.3-3.5 4.3 3.1c.7.5 1.7.1 1.8-.8L21 4Z', 'm8.4 13.7 8.8-6.5'],
  weibo: ['M8.3 16.7c-2.5 0-4.5-1.2-4.5-2.8s2-2.9 4.5-2.9 4.5 1.3 4.5 2.9-2 2.8-4.5 2.8Z', 'M11.5 9.6c.8-.5 1.8-.8 2.8-.8 2.3 0 4.2 1.4 4.2 3.2 0 .9-.5 1.7-1.3 2.3', 'M15.5 4.5c1.8.2 3.2 1.6 3.4 3.4M16 7.2c.7.1 1.2.6 1.3 1.3', 'M7.5 13.4h.01M9.7 13h.01'],
  x: ['M4 4h4.2l11.8 16h-4.2L4 4Z', 'M20 4 4 20'],
  youtube: ['M21 12s0-3.2-.4-4.2c-.2-.6-.7-1.1-1.3-1.3C18.2 6 12 6 12 6s-6.2 0-7.3.5c-.6.2-1.1.7-1.3 1.3C3 8.8 3 12 3 12s0 3.2.4 4.2c.2.6.7 1.1 1.3 1.3 1.1.5 7.3.5 7.3.5s6.2 0 7.3-.5c.6-.2 1.1-.7 1.3-1.3.4-1 .4-4.2.4-4.2Z', 'm10 9 5 3-5 3V9Z'],
  link: ['M10 13a5 5 0 0 0 7.1.1l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1', 'M14 11a5 5 0 0 0-7.1-.1l-2 2a5 5 0 0 0 7.1 7.1l1.1-1.1'],
};

const items = copy.items
  .filter((item) => item.enabled !== false && item.href)
  .sort((a, b) => Number(Boolean(b.featured)) - Number(Boolean(a.featured)))
  .slice(0, copy.maxVisible ?? copy.items.length);
---

{copy.enabled !== false && items.length > 0 && (
  <aside class="social-contact" id="social-contact" data-social-contact>
    <div class="social-contact__panel" id="social-contact-panel" data-social-contact-panel hidden>
      <div class="social-contact__head">
        <div>
          <p>{copy.eyebrow}</p>
          <h2>{copy.title}</h2>
        </div>
        <button type="button" data-social-contact-close aria-label={copy.closeLabel}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
      {copy.helper && <p class="social-contact__helper">{copy.helper}</p>}
      <div class="social-contact__list">
        {items.map((item) => {
          const icon = iconPaths[item.icon ?? 'link'] ?? iconPaths.link;
          return (
            <a class:list={['social-contact__link', { 'is-featured': item.featured }]} href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
              <span class="social-contact__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  {icon.map((path) => <path d={path} />)}
                </svg>
              </span>
              <span class="social-contact__text">
                <strong>{item.label}</strong>
                {(item.handle || item.description) && <small>{item.handle || item.description}</small>}
              </span>
            </a>
          );
        })}
      </div>
    </div>
    <button
      class="social-contact__toggle"
      type="button"
      data-social-contact-toggle
      aria-label={copy.buttonLabel}
      aria-controls="social-contact-panel"
      aria-expanded="false"
    >
      <span aria-hidden="true">//</span>
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M7 10.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7ZM17 20.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7ZM9.9 8.6l4.2 6.8" />
      </svg>
    </button>
  </aside>
)}

<script>
  import '../scripts/socialContact.js';
</script>
