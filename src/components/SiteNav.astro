---
type NavItem = {
  label: string;
  href: string;
};

type LocaleLink = {
  code: string;
  label: string;
  shortLabel: string;
  href: string;
  current: boolean;
};

const { navItems, localeLinks, brandLines, compact = false } = Astro.props as {
  navItems: NavItem[];
  localeLinks: LocaleLink[];
  brandLines: string[];
  compact?: boolean;
  homeHref?: string;
};

const { homeHref = '/' } = Astro.props as { homeHref?: string };
const resolvedNavItems = compact
  ? navItems.map((item) => ({
      ...item,
      href: item.href.startsWith('#') ? `${homeHref}${item.href}` : item.href,
    }))
  : navItems;
---

<nav class:list={[
  'fixed top-0 w-full z-50 mix-blend-difference flex justify-between pointer-events-none',
  compact ? 'items-center px-4 py-4 md:px-8 md:py-5' : 'items-start px-6 py-8 md:px-12',
]}>
  <a href={homeHref} class="pointer-events-auto group">
    <p class:list={[
      'text-white tracking-kamidest font-light uppercase group-hover:opacity-50 transition-opacity duration-500',
      compact ? 'text-[9px] leading-snug md:text-[10px]' : 'text-[10px] leading-relaxed md:text-xs',
    ]}>
      {compact ? (
        <>
          <span class="sm:hidden">Kamitsubaki Studio Fan Wiki</span>
          <span class="hidden sm:inline">{brandLines.join(' ')}</span>
        </>
      ) : (
        brandLines.map((line, index) => (
          <>
            {line}{index < brandLines.length - 1 && <br />}
          </>
        ))
      )}
    </p>
  </a>
  <div class:list={[
    'pointer-events-auto flex items-end text-[9px] md:text-[10px] tracking-kamidest-lg font-light text-white',
    compact ? 'flex-row gap-5' : 'flex-col gap-3',
  ]}>
    {compact && (
      <details class="site-nav__menu pointer-events-auto md:hidden">
        <summary aria-label="Open navigation">MENU</summary>
        <div class="site-nav__menu-panel">
          {resolvedNavItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </details>
    )}
    {resolvedNavItems.map((item) => (
      <a href={item.href} class={compact ? 'site-nav__link hidden md:inline hover:text-white/50 transition-all duration-300' : 'site-nav__link hover:text-white/50 transition-all duration-300'}>{item.label}</a>
    ))}
    <div class:list={[
      'flex gap-3 font-mono tracking-widest text-[8px]',
      compact ? 'mt-0' : 'mt-4',
    ]} aria-label="Language switcher">
      {localeLinks.map((item) => (
        <a
          href={item.href}
          aria-current={item.current ? 'page' : undefined}
          title={item.label}
          class={item.current ? 'text-white' : 'text-white/35 hover:text-white transition-colors'}
        >
          {item.shortLabel}
        </a>
      ))}
    </div>
  </div>
</nav>
