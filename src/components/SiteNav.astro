---
type NavItem = {
  label: string;
  href: string;
};

const { navItems } = Astro.props as { navItems: NavItem[] };
---

<nav class="fixed top-0 w-full z-50 mix-blend-difference px-6 md:px-12 py-8 flex justify-between items-start pointer-events-none">
  <a href="#" class="pointer-events-auto group">
    <h1 class="text-white text-[10px] md:text-xs tracking-kamidest font-light uppercase group-hover:opacity-50 transition-opacity duration-500 leading-relaxed">
      Kamitsubaki<br />Studio<br />Unofficial Wiki
    </h1>
  </a>
  <div class="pointer-events-auto flex flex-col items-end gap-3 text-[9px] md:text-[10px] tracking-kamidest-lg font-light text-white">
    {navItems.map((item) => (
      <a href={item.href} class="hover:text-white/50 transition-all duration-300">{item.label}</a>
    ))}
  </div>
</nav>
