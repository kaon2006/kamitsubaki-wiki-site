---
type Project = {
  id: string;
  href: string;
  categorySlug: string;
  categoryTitle: string;
  kind: string;
  title: string;
  description: string;
};

const { projects, section } = Astro.props as {
  projects: Project[];
  section: {
    heading: string;
    subheading: string;
    viewAllLabel: string;
  };
};
---

<section id="projects" class="py-32 px-6 max-w-7xl mx-auto border-t border-white/10 relative ui-crosshair bl br">
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 reveal-up">
    <div>
      <h3 class="text-[10px] tracking-kamidest-lg font-light text-white mb-2">{section.heading}</h3>
      <p class="font-serif text-[10px] text-white/50 tracking-widest">{section.subheading}</p>
    </div>
    <a href="#" class="text-[9px] font-mono text-white/40 hover:text-white transition-colors border-b border-transparent hover:border-white pb-1 mt-6 md:mt-0">
      {section.viewAllLabel}
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
    {projects.map((project, index) => (
      <a
        href={project.href}
        class="group relative block overflow-hidden rounded-md border border-white/10 bg-white/[0.025] p-6 transition-colors duration-500 hover:border-white/35 reveal-up"
        style={`transition-delay: ${index * 0.1}s;`}
      >
        <div class="absolute inset-0 bg-white/[0.04] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
        <div class="relative z-10 flex min-h-56 flex-col">
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="mb-3 block text-[8px] font-mono text-white/28">{project.kind}</span>
              <p class="text-[9px] font-mono uppercase tracking-[0.18em] text-white/40">{project.categoryTitle}</p>
            </div>
            <span class="text-[9px] font-mono text-white/20 transition-colors duration-300 group-hover:text-white/50">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>

          <div class="mt-8 flex-1">
            <h4 class="font-serif text-xl text-white/82 transition-colors duration-300 group-hover:text-white sm:text-2xl">
            {project.title}
            </h4>
            {project.description && (
              <p class="mt-4 max-w-sm text-[12px] leading-7 text-white/46 sm:text-[13px]">
                {project.description}
              </p>
            )}
          </div>

          <div class="mt-8 flex items-center justify-between border-t border-white/10 pt-4 text-[9px] font-mono uppercase tracking-[0.18em] text-white/35">
            <span>{project.id}</span>
            <span class="transition-colors duration-300 group-hover:text-white/72">Open</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
