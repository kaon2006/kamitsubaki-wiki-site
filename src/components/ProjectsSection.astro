---
type Project = {
  kind: string;
  title: string;
  description: string;
};

const { projects } = Astro.props as { projects: Project[] };
---

<section id="projects" class="py-32 px-6 max-w-7xl mx-auto border-t border-white/10 relative ui-crosshair bl br">
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 reveal-up">
    <div>
      <h3 class="text-[10px] tracking-kamidest-lg font-light text-white mb-2">02. PROTOCOLS</h3>
      <p class="font-serif text-[10px] text-white/50 tracking-widest">派生計画・プロジェクト</p>
    </div>
    <a href="#" class="text-[9px] font-mono text-white/40 hover:text-white transition-colors border-b border-transparent hover:border-white pb-1 mt-6 md:mt-0">
      VIEW ALL PROTOCOLS >>
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {projects.map((project, index) => (
      <a
        href="#"
        class="group block border border-white/10 p-8 hover:border-white/40 transition-colors duration-500 relative overflow-hidden reveal-up"
        style={`transition-delay: ${index * 0.1}s;`}
      >
        <div class="absolute inset-0 bg-white/5 transform -translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
        <div class="relative z-10">
          <span class="text-[8px] font-mono text-white/30 mb-4 block">{project.kind}</span>
          <h4 class="font-serif text-xl text-white/80 mb-2 tracking-widest group-hover:text-white transition-colors">
            {project.title}
          </h4>
          <p class="text-[10px] text-white/40 leading-loose">{project.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>
