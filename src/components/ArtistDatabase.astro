---
type DatabaseJumpLink = {
  label: string;
  href: string;
};

type Artist = {
  id: string;
  code: string;
  name: string;
  romanizedName: string;
  meta?: string;
  statusLabel: string;
  status: string;
  contentStatus?: 'stub' | 'published';
  inactive?: boolean;
  image: string;
};

type ArtistCategory = {
  id: string;
  title: string;
  subtitle: string;
  items: Artist[];
};

const { artistCategories, databaseJumpLinks, section, locale = 'zh' } = Astro.props as {
  artistCategories: ArtistCategory[];
  databaseJumpLinks: DatabaseJumpLink[];
  section: {
    heading: string;
    subheading: string;
    expandLabel?: string;
  };
  locale: 'zh' | 'ja' | 'en';
};

const stubLabel = { zh: '待完善', ja: '未完成', en: 'STUB' }[locale];
const ITEMS_PER_CATEGORY = 6;
---

<section id="database" class="relative mx-auto max-w-7xl px-5 py-20 ui-crosshair bl br tl tr sm:px-6 sm:py-32">
  <div id="artist-bg-container" class="artist-bg fixed-bg-hack pointer-events-none">
    <div class="absolute inset-0 z-10 bg-[#030303] opacity-65 mix-blend-multiply"></div>
    <img
      id="artist-bg-img"
      src=""
      alt=""
      class="artist-bg__image saturate-125"
      aria-hidden="true"
    />
    <img src="" alt="" class="artist-bg__image saturate-125" aria-hidden="true" />
  </div>

  <div class="relative z-10 grid grid-cols-1 gap-9 sm:gap-12 lg:grid-cols-12 lg:gap-24">
    <div class="lg:col-span-3">
      <div class="sticky top-32 reveal-up">
        <h3 class="text-[10px] tracking-kamidest-lg font-light text-white mb-2">{section.heading}</h3>
        <p class="font-serif text-[10px] text-white/50 tracking-widest mb-12">{section.subheading}</p>

        <div class="hidden lg:flex flex-col gap-5 text-[9px] font-mono tracking-widest text-white/30 border-l border-white/10 pl-4">
          {databaseJumpLinks.map((item) => (
            <a href={item.href} class="hover:text-white transition-colors hover:pl-2 duration-300">{item.label}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="lg:col-span-9 flex flex-col pb-20" id="artist-list">
      {artistCategories.map((category) => {
        const hasMore = category.items.length > ITEMS_PER_CATEGORY;
        const collapsedId = `${category.id}-collapsed`;

        return (
          <div id={category.id} class="artist-category mb-16 pt-8 scroll-mt-32 last:mb-8 sm:mb-24 sm:last:mb-12">
            <div class="border-b border-white/20 pb-4 mb-4 flex justify-between items-end reveal-up">
              <h4 class="font-serif text-base tracking-[0.4em] text-white/80">{category.title}</h4>
              <span class="text-[9px] font-mono text-white/40 hidden md:block">{category.subtitle}</span>
            </div>

            <div id={collapsedId}>
              {category.items.map((artist, idx) => (
                <a
                  href={`/${locale}/artists/${artist.id}`}
                  class={`artist-row group block list-row py-6 reveal-up${idx >= ITEMS_PER_CATEGORY ? ' artist-row-collapsed hidden' : ''}`}
                  data-img={artist.image}
                >
                  <div class="flex flex-col md:flex-row md:items-center justify-between px-4 gap-4">
                    <div class="flex items-center gap-6">
                      <span class="font-mono text-[9px] text-white/20 w-6">{artist.code}</span>
                      <h4 class="font-serif text-xl md:text-2xl text-white/60 tracking-[0.2em]">
                        {artist.name}
                      </h4>
                      <span class="text-[9px] tracking-kamidest font-light text-white/30">
                        {artist.romanizedName}
                      </span>
                      {artist.contentStatus === 'stub' && (
                        <span class="rounded-full border border-amber-200/20 px-2 py-1 font-mono text-[8px] tracking-widest text-amber-100/60">{stubLabel}</span>
                      )}
                    </div>
                    <div class="text-[8px] font-mono text-white/30 flex gap-6 md:text-right">
                      {artist.meta && <span class="hidden md:block">{artist.meta}</span>}
                      <span class="w-16 text-left md:text-right">
                        {artist.statusLabel}: <span class={artist.inactive ? 'text-white/30 line-through' : 'text-white/70'}>{artist.status}</span>
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>

            {hasMore && (
              <button
                type="button"
                class="artist-expand-btn group"
                aria-label={section.expandLabel ?? 'Expand'}
                aria-expanded="false"
                aria-controls={collapsedId}
                data-category-id={category.id}
              >
                <div class="artist-expand-divider">
                  <div class="artist-expand-line artist-expand-line--left"></div>
                  <svg
                    class="artist-expand-chevron w-3 h-3"
                    viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <div class="artist-expand-line artist-expand-line--right"></div>
                </div>
              </button>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
