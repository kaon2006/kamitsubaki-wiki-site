---
type LogEntry = {
  date: string;
  type: string;
  message: string;
};

const { logEntries } = Astro.props as { logEntries: LogEntry[] };
---

<section id="log" class="py-32 px-6 max-w-7xl mx-auto border-t border-white/10 relative ui-crosshair bl br tl tr">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
    <div class="md:col-span-3 reveal-up">
      <h3 class="text-[10px] tracking-kamidest-lg font-light text-white mb-2">03. LOG</h3>
      <p class="font-serif text-[10px] text-white/50 tracking-widest">観測記録</p>
    </div>

    <div class="md:col-span-9 flex flex-col font-mono text-[9px] md:text-[10px]">
      {logEntries.map((entry) => (
        <a href="#" class="group flex flex-col md:flex-row md:items-center gap-4 md:gap-12 py-4 border-b border-white/10 hover:bg-white/5 transition-colors px-4 reveal-up">
          <span class="text-white/40 w-24">{entry.date}</span>
          <span class="tracking-widest border border-white/20 px-2 py-1 w-max text-white/60">{entry.type}</span>
          <span class="text-white/60 group-hover:text-white">{entry.message}</span>
        </a>
      ))}
    </div>
  </div>
</section>
