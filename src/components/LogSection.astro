---
type LogEntry = {
  id: string;
  href: string;
  date: string;
  type: string;
  title: string;
  summary?: string;
};

const { logEntries, section } = Astro.props as {
  logEntries: LogEntry[];
  section: {
    heading: string;
    subheading: string;
  };
};
---

<section id="log" class="py-32 px-6 max-w-7xl mx-auto border-t border-white/10 relative ui-crosshair bl br tl tr">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
    <div class="md:col-span-3 reveal-up">
      <h3 class="text-[10px] tracking-kamidest-lg font-light text-white mb-2">{section.heading}</h3>
      <p class="font-serif text-[10px] text-white/50 tracking-widest">{section.subheading}</p>
    </div>

    <div class="md:col-span-9 grid gap-5 md:gap-6">
      {logEntries.map((entry, index) => (
        <a
          href={entry.href}
          class="group relative overflow-hidden rounded-md border border-white/10 bg-white/[0.025] p-5 transition-colors duration-500 hover:border-white/35 reveal-up sm:p-6"
          style={`transition-delay: ${index * 0.08}s;`}
        >
          <div class="absolute inset-0 bg-white/[0.04] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <article class="relative z-10 grid gap-5 md:grid-cols-[8rem_minmax(0,1fr)] md:gap-6">
            <div class="space-y-3 border-b border-white/10 pb-4 md:border-b-0 md:border-r md:border-white/10 md:pb-0 md:pr-6">
              <p class="text-[9px] font-mono uppercase tracking-[0.18em] text-white/42">{entry.date}</p>
              <span class="inline-flex w-max items-center rounded-sm border border-white/14 px-2.5 py-1 text-[8px] font-mono uppercase tracking-[0.18em] text-white/58">
                {entry.type}
              </span>
            </div>

            <div class="min-w-0">
              <h4 class="font-serif text-xl text-white/84 transition-colors duration-300 group-hover:text-white sm:text-2xl">
                {entry.title}
              </h4>
              {entry.summary && (
                <p class="mt-3 max-w-2xl text-[13px] leading-7 text-white/48 sm:text-[14px] sm:leading-8">
                  {entry.summary}
                </p>
              )}
              <div class="mt-5 flex items-center justify-between border-t border-white/10 pt-4 text-[9px] font-mono uppercase tracking-[0.16em] text-white/34">
                <span>{entry.id}</span>
                <span class="transition-colors duration-300 group-hover:text-white/72">Read</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>
