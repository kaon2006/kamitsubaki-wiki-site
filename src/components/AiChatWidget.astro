---
type AiChatCopy = {
  title: string;
  status: string;
  buttonLabel: string;
  closeLabel: string;
  minimizeLabel: string;
  inputLabel: string;
  inputPlaceholder: string;
  sendLabel: string;
  keyboardHint?: string;
  modelModeLabel: string;
  thinkingModeLabel: string;
  modelModes: { value: string; label: string }[];
  thinkingModes: { value: string; label: string }[];
  bubbleIdle: string;
  bubbleThinking: string;
  thinkingPhrases?: string[];
  greeting: string;
  fallbackOffline: string;
  emptyResponse: string;
  challengeFallback: string;
  streamErrorFallback: string;
  accountAnonymous: string;
  accountLoggedInPrefix: string;
  loginRequiredFallback?: string;
  githubLoginLabel: string;
  googleLoginLabel: string;
  logoutLabel: string;
  authErrorFallback: string;
  historyLabel?: string;
  historyEmpty?: string;
  newThreadLabel?: string;
  renameThreadLabel?: string;
  deleteThreadLabel?: string;
  clearHistoryLabel?: string;
  renameThreadPrompt?: string;
  deleteThreadConfirm?: string;
  clearHistoryConfirm?: string;
  quickPrompts: string[];
};

const { lang = 'zh', copy } = Astro.props as { lang?: string; copy: AiChatCopy };
const normalizedCopy = {
  ...copy,
  modelModeLabel: copy.modelModeLabel ?? 'Model',
  thinkingModeLabel: copy.thinkingModeLabel ?? 'Thinking',
  keyboardHint: copy.keyboardHint ?? 'Enter sends · Control+Enter newline',
  accountAnonymous: copy.accountAnonymous ?? 'Anonymous observer',
  accountLoggedInPrefix: copy.accountLoggedInPrefix ?? 'Signed in',
  loginRequiredFallback: copy.loginRequiredFallback ?? 'Anonymous limit reached. Sign in to continue.',
  githubLoginLabel: copy.githubLoginLabel ?? 'Continue with GitHub',
  googleLoginLabel: copy.googleLoginLabel ?? 'Continue with Google',
  logoutLabel: copy.logoutLabel ?? 'Sign out',
  authErrorFallback: copy.authErrorFallback ?? 'The auth line is unstable.',
  historyLabel: copy.historyLabel ?? 'History',
  historyEmpty: copy.historyEmpty ?? 'No conversations yet.',
  newThreadLabel: copy.newThreadLabel ?? 'New chat',
  renameThreadLabel: copy.renameThreadLabel ?? 'Rename',
  deleteThreadLabel: copy.deleteThreadLabel ?? 'Delete',
  clearHistoryLabel: copy.clearHistoryLabel ?? 'Clear history',
  renameThreadPrompt: copy.renameThreadPrompt ?? 'Conversation title',
  deleteThreadConfirm: copy.deleteThreadConfirm ?? 'Delete this conversation?',
  clearHistoryConfirm: copy.clearHistoryConfirm ?? 'Delete all conversations?',
  thinkingPhrases: copy.thinkingPhrases ?? [copy.bubbleThinking ?? 'Thinking'],
  modelModes: (copy.modelModes ?? [
    { value: 'auto', label: 'Auto' },
    { value: 'fast', label: 'Fast' },
    { value: 'balanced', label: 'Balanced' },
    { value: 'deep', label: 'Deep' },
  ]).filter((mode) => mode.value !== 'custom'),
  thinkingModes: copy.thinkingModes ?? [
    { value: 'auto', label: 'Auto' },
    { value: 'off', label: 'Off' },
    { value: 'light', label: 'Light' },
    { value: 'deep', label: 'Deep' },
  ],
};
const apiBase = import.meta.env.PUBLIC_AI_OBSERVER_API_BASE || 'https://api.kamitsubaki.wiki';
---

<div class="ai-chat__launcher" data-ai-launcher>
  <div class="ai-chat__bubble" data-ai-bubble aria-hidden="true">{copy.bubbleIdle}</div>
  <button
    class="ai-chat__orb"
    type="button"
    data-ai-toggle
    aria-label={copy.buttonLabel}
    aria-expanded="false"
  >
    <span class="ai-chat__orb-corner ai-chat__orb-corner--tl" aria-hidden="true">+</span>
    <span class="ai-chat__orb-corner ai-chat__orb-corner--tr" aria-hidden="true">+</span>
    <span class="ai-chat__orb-corner ai-chat__orb-corner--bl" aria-hidden="true">+</span>
    <span class="ai-chat__orb-corner ai-chat__orb-corner--br" aria-hidden="true">+</span>
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M12 2C12 7.5 16.5 12 22 12C16.5 12 12 16.5 12 22C12 16.5 7.5 12 2 12C7.5 12 12 7.5 12 2Z" fill="currentColor" stroke="none" />
    </svg>
  </button>
</div>

<aside
  class="ai-chat fixed inset-0 z-50 font-mono"
  data-ai-chat
  data-api-base={apiBase}
  data-locale={lang}
  data-copy={JSON.stringify(normalizedCopy)}
  aria-label={copy.title}
>
  <button
    class="ai-chat__scrim"
    type="button"
    data-ai-scrim
    aria-label={copy.closeLabel}
  ></button>

  <section class="ai-chat__panel" data-ai-panel aria-hidden="true">
    <div class="ai-chat__hud-grid"></div>

    <header class="ai-chat__header">
      <div class="ai-chat__title-block">
        <span class="ai-chat__sys-status">SYS_LINK // {copy.status}</span>
        <h2 class="ai-chat__sys-title">{copy.title}</h2>
      </div>

      <div class="ai-chat__actions">
        <button class="ai-chat__icon-btn" type="button" data-ai-history-toggle aria-expanded="false" aria-label="History">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/><path d="M12 7v5l3 2"/></svg>
        </button>
        <button class="ai-chat__icon-btn" type="button" data-ai-settings-toggle aria-expanded="false" aria-label="Settings">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M4 7h10"/><path d="M18 7h2"/><path d="M16 5v4"/><path d="M4 17h2"/><path d="M10 17h10"/><path d="M8 15v4"/></svg>
        </button>
        <button class="ai-chat__icon-btn ai-chat__icon-btn--close" type="button" data-ai-close aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M18 6 6 18M6 6l12 12" /></svg>
        </button>
      </div>

      <div class="ai-chat__settings-popover" data-ai-settings-popover hidden>
        <div class="ai-chat__controls" data-ai-controls>
          <div class="ai-chat__control-group">
            <span>// {normalizedCopy.modelModeLabel}</span>
            <div class="ai-chat__segmented" role="radiogroup" data-ai-model-choice data-value={normalizedCopy.modelModes[0]?.value ?? 'auto'}>
              {normalizedCopy.modelModes.map((mode, index) => (
                <button type="button" role="radio" data-ai-model-option={mode.value} aria-checked={index === 0 ? 'true' : 'false'} class={index === 0 ? 'is-active' : ''}>
                  {mode.label}
                </button>
              ))}
            </div>
          </div>
          <div class="ai-chat__control-group">
            <span>// {normalizedCopy.thinkingModeLabel}</span>
            <div class="ai-chat__segmented" role="radiogroup" data-ai-thinking-mode data-value={normalizedCopy.thinkingModes[0]?.value ?? 'auto'}>
              {normalizedCopy.thinkingModes.map((mode, index) => (
                <button type="button" role="radio" data-ai-thinking-option={mode.value} aria-checked={index === 0 ? 'true' : 'false'} class={index === 0 ? 'is-active' : ''}>
                  {mode.label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="ai-chat__session-bar">
      <div class="ai-chat__auth" data-ai-auth>
        <div class="ai-chat__auth-status" data-ai-auth-status>{normalizedCopy.accountAnonymous}</div>
        <div class="ai-chat__auth-actions">
          <button class="ai-chat__auth-btn" type="button" data-ai-oauth="github"><svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg> {normalizedCopy.githubLoginLabel}</button>
          <button class="ai-chat__auth-btn" type="button" data-ai-oauth="google"><svg viewBox="0 0 48 48" aria-hidden="true"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12S17.373 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg> {normalizedCopy.googleLoginLabel}</button>
          <button class="ai-chat__auth-btn" type="button" data-ai-logout hidden><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg> {normalizedCopy.logoutLabel}</button>
        </div>
      </div>
      <p data-ai-auth-note hidden></p>
    </div>

    <div class="ai-chat__body">
      <aside class="ai-chat__history" data-ai-history-panel hidden>
        <div class="ai-chat__history-head">
          <span>// ARCHIVES</span>
          <div class="ai-chat__history-actions">
            <button type="button" class="ai-chat__icon-btn" data-ai-new-thread><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 5v14M5 12h14"/></svg></button>
            <button type="button" class="ai-chat__icon-btn" data-ai-history-clear><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
          </div>
        </div>
        <template data-ai-thread-menu></template>
        <div class="ai-chat__thread-list" data-ai-thread-list data-empty={normalizedCopy.historyEmpty} aria-live="polite"></div>
      </aside>

      <main class="ai-chat__main">
        <div class="ai-chat__messages" data-ai-messages role="log" aria-live="polite">
          <article class="ai-message ai-message--assistant">
            <div class="ai-message__avatar" aria-hidden="true">
              SYS
            </div>
            <div class="ai-message__content ai-markdown">
              <p>{copy.greeting}</p>
            </div>
          </article>
        </div>

        <div class="ai-chat__quick" data-ai-quick>
          {copy.quickPrompts.map((prompt) => <button type="button" data-ai-prompt={prompt}>&gt; {prompt}</button>)}
        </div>

        <div class="ai-chat__challenge-tray" data-ai-challenge-tray hidden aria-live="polite">
          <div class="ai-chat__challenge-shell">
            <span class="ai-chat__challenge-label">SECURITY CHECK</span>
            <div class="ai-chat__challenge-mount" data-ai-challenge-mount></div>
          </div>
        </div>

        <form class="ai-chat__form" data-ai-form>
          <div class="ai-chat__composer">
            <span class="ai-chat__prompt-symbol">&gt;_</span>
            <textarea
              id="ai-chat-input"
              data-ai-input
              rows="1"
              maxlength="5000"
              placeholder={copy.inputPlaceholder}
            ></textarea>
            <button type="submit" class="ai-chat__submit-btn" data-ai-submit aria-label={copy.sendLabel}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
          <p class="ai-chat__hint">{normalizedCopy.keyboardHint}</p>
        </form>
      </main>
    </div>

  </section>

  <dialog class="ai-chat__dialog" data-ai-history-dialog>
    <form method="dialog">
      <div class="ai-chat__dialog-glow" aria-hidden="true"></div>
      <h3 data-ai-dialog-title></h3>
      <p data-ai-dialog-message></p>
      <input data-ai-dialog-input type="text" maxlength="80" autocomplete="off" />
      <div class="ai-chat__dialog-actions">
        <button class="ai-chat__hud-btn" type="submit" value="cancel">[CANCEL]</button>
        <button class="ai-chat__hud-btn is-primary" type="submit" value="confirm" data-ai-dialog-confirm></button>
      </div>
    </form>
  </dialog>
</aside>

<script>
  import '../scripts/aiChatWidget.js';
</script>
