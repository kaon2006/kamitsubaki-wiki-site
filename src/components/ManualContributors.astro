---
import manualContributorData from '../data/manualContributors.json';

type ContributorLocale = 'zh' | 'ja' | 'en';
type LocalizedContributorText = string | Partial<Record<ContributorLocale, string>>;

interface ManualContributor {
  id: string;
  collaboration: LocalizedContributorText;
  name: string;
  avatar?: string;
  contacts: Array<{ label: string; href?: string }>;
  introduction: LocalizedContributorText;
  quote: LocalizedContributorText;
  enabled?: boolean;
}

interface Props {
  locale?: ContributorLocale | string;
}

const { locale = 'zh' } = Astro.props as Props;
const activeLocale: ContributorLocale = locale === 'ja' || locale === 'en' ? locale : 'zh';
const contributors = (manualContributorData as ManualContributor[]).filter((contributor) => contributor.enabled !== false);

const copy = {
  zh: {
    title: '特别协力者',
    subtitle: '感谢以不同方式为这座观测站提供帮助的每一位同行者。点击头像查看他们的故事。',
    contact: '联系方式',
    quote: '他的一句话',
    open: '查看资料',
    close: '收起资料',
    showAll: '展开全部',
    showLess: '收起名单',
    empty: '手动协力者名单尚未添加。可在本地数据文件中补充。',
  },
  ja: {
    title: 'スペシャルサポーター',
    subtitle: 'さまざまな形でこの観測拠点を支えてくださった皆さまに感謝します。アイコンを選ぶとプロフィールが開きます。',
    contact: '連絡先',
    quote: 'ひとこと',
    open: 'プロフィールを見る',
    close: 'プロフィールを閉じる',
    showAll: 'すべて表示',
    showLess: '折りたたむ',
    empty: '手動サポーターはまだ登録されていません。ローカルデータファイルから追加できます。',
  },
  en: {
    title: 'Special collaborators',
    subtitle: 'With thanks to everyone who supports this observatory in their own way. Select a portrait to meet them.',
    contact: 'Contact',
    quote: 'In their words',
    open: 'View profile',
    close: 'Close profile',
    showAll: 'Show all',
    showLess: 'Show less',
    empty: 'No manual collaborators have been added yet. Add them in the local data file.',
  },
}[activeLocale];

function localized(value: LocalizedContributorText) {
  if (typeof value === 'string') return value;
  return value[activeLocale] || value.zh || value.ja || value.en || '';
}

function safeContactHref(value?: string) {
  if (!value) return '';
  if (value.startsWith('mailto:')) return value;

  try {
    const url = new URL(value);
    return url.protocol === 'https:' || url.protocol === 'http:' ? value : '';
  } catch {
    return '';
  }
}

function safeAvatarSrc(value?: string) {
  if (!value) return '';
  if (value.startsWith('/') && !value.startsWith('//')) return value;

  try {
    const url = new URL(value);
    return url.protocol === 'https:' || url.protocol === 'http:' ? value : '';
  } catch {
    return '';
  }
}

function initials(name: string) {
  return Array.from(name.trim()).slice(0, 2).join('').toUpperCase() || '?';
}
---

<section
  class="manual-contributors"
  aria-labelledby="manual-contributors-title"
  data-manual-contributors
  data-list-expanded="false"
  data-detail-open="false"
  data-has-overflow="false"
>
  <header class="manual-contributors__header">
    <div>
      <h3 id="manual-contributors-title">{copy.title}</h3>
      <p>{copy.subtitle}</p>
    </div>
    <span aria-label={`${contributors.length} ${copy.title}`}>{String(contributors.length).padStart(2, '0')}</span>
  </header>

  {contributors.length > 0 ? (
    <>
      <div class="manual-contributors__grid-wrap">
        <div class="manual-contributors__grid" data-contributor-grid>
          {contributors.map((contributor) => {
            const avatarSrc = safeAvatarSrc(contributor.avatar);
            const detailId = `manual-contributor-${contributor.id}`;

            return (
              <button
                class="manual-contributors__card"
                type="button"
                aria-expanded="false"
                aria-controls={detailId}
                aria-label={`${copy.open}：${contributor.name}`}
                data-contributor-card={contributor.id}
              >
                <span class="manual-contributors__avatar">
                  {avatarSrc ? (
                    <img src={avatarSrc} alt="" loading="lazy" referrerpolicy="no-referrer" />
                  ) : (
                    <span>{initials(contributor.name)}</span>
                  )}
                </span>
                <span class="manual-contributors__card-copy">
                  <strong>{contributor.name}</strong>
                  <small>{localized(contributor.collaboration)}</small>
                </span>
                <span class="manual-contributors__card-mark" aria-hidden="true">↗</span>
              </button>
            );
          })}
        </div>
      </div>

      <button
        class="manual-contributors__toggle"
        type="button"
        aria-expanded="false"
        data-contributor-list-toggle
        data-show-all={copy.showAll}
        data-show-less={copy.showLess}
      >
        <span>{copy.showAll}</span><i aria-hidden="true">⌄</i>
      </button>

      <div class="manual-contributors__drawer" data-contributor-drawer>
        <div class="manual-contributors__drawer-clip">
          <div class="manual-contributors__drawer-surface">
            <button class="manual-contributors__drawer-close" type="button" aria-label={copy.close} data-contributor-close>×</button>
            {contributors.map((contributor) => {
              const avatarSrc = safeAvatarSrc(contributor.avatar);
              const contacts = Array.isArray(contributor.contacts) ? contributor.contacts : [];

              return (
                <article id={`manual-contributor-${contributor.id}`} class="manual-contributors__detail" hidden data-contributor-detail={contributor.id}>
                  <div class="manual-contributors__identity">
                    <span class="manual-contributors__detail-avatar">
                      {avatarSrc ? (
                        <img src={avatarSrc} alt="" loading="lazy" referrerpolicy="no-referrer" />
                      ) : (
                        <span>{initials(contributor.name)}</span>
                      )}
                    </span>
                    <div>
                      <p>{localized(contributor.collaboration)}</p>
                      <h4>{contributor.name}</h4>
                    </div>
                  </div>

                  <div class="manual-contributors__bio">
                    <p>{localized(contributor.introduction)}</p>
                    {contacts.length > 0 && (
                      <div class="manual-contributors__contacts">
                        <span>{copy.contact}</span>
                        <div>
                          {contacts.map((contact) => {
                            const contactHref = safeContactHref(contact.href);
                            return contactHref ? (
                              <a href={contactHref} target={contactHref.startsWith('mailto:') ? undefined : '_blank'} rel={contactHref.startsWith('mailto:') ? undefined : 'noopener noreferrer'}>
                                {contact.label}<span aria-hidden="true">↗</span>
                              </a>
                            ) : (
                              <strong>{contact.label}</strong>
                            );
                          })}
                        </div>
                      </div>
                    )}
                  </div>

                  <blockquote>
                    <span>{copy.quote}</span>
                    <p>“{localized(contributor.quote)}”</p>
                  </blockquote>
                </article>
              );
            })}
          </div>
        </div>
      </div>
    </>
  ) : (
    <p class="manual-contributors__empty">{copy.empty}</p>
  )}
</section>

<script>
  function initializeManualContributors() {
    document.querySelectorAll<HTMLElement>('[data-manual-contributors]').forEach((root) => {
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const grid = root.querySelector<HTMLElement>('[data-contributor-grid]');
      const listToggle = root.querySelector<HTMLButtonElement>('[data-contributor-list-toggle]');
      const closeButton = root.querySelector<HTMLButtonElement>('[data-contributor-close]');
      const cards = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-contributor-card]'));
      const details = Array.from(root.querySelectorAll<HTMLElement>('[data-contributor-detail]'));
      let selectedId = '';

      const closeDetail = () => {
        root.dataset.detailOpen = 'false';
        cards.forEach((card) => card.setAttribute('aria-expanded', 'false'));
        selectedId = '';
      };

      const updateOverflow = () => {
        if (!grid || root.dataset.listExpanded === 'true') return;
        root.dataset.hasOverflow = String(grid.scrollHeight > grid.clientHeight + 2);
      };

      cards.forEach((card) => {
        card.addEventListener('click', () => {
          const id = card.dataset.contributorCard || '';
          if (selectedId === id && root.dataset.detailOpen === 'true') {
            closeDetail();
            return;
          }

          details.forEach((detail) => {
            detail.hidden = detail.dataset.contributorDetail !== id;
          });
          cards.forEach((item) => item.setAttribute('aria-expanded', String(item === card)));
          selectedId = id;
          root.dataset.detailOpen = 'true';
        });
      });

      closeButton?.addEventListener('click', closeDetail);

      listToggle?.addEventListener('click', () => {
        const expanded = root.dataset.listExpanded !== 'true';
        root.dataset.listExpanded = String(expanded);
        listToggle.setAttribute('aria-expanded', String(expanded));
        const label = listToggle.querySelector('span');
        if (label) label.textContent = expanded ? listToggle.dataset.showLess || '' : listToggle.dataset.showAll || '';
      });

      updateOverflow();
      window.addEventListener('resize', updateOverflow, { passive: true });
    });
  }

  initializeManualContributors();
  document.addEventListener('astro:page-load', initializeManualContributors);
</script>

<style>
  .manual-contributors {
    --manual-card-size: 7rem;
    --manual-grid-gap: 0.65rem;
    margin: 0 0 clamp(2rem, 5vw, 3.5rem);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .manual-contributors__header {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    justify-content: space-between;
    padding: clamp(1.75rem, 4vw, 2.75rem) 0 1.25rem;
  }

  .manual-contributors__header h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 2.2vw, 1.6rem);
    font-weight: 400;
    letter-spacing: 0.07em;
    color: rgba(255, 255, 255, 0.92);
  }

  .manual-contributors__header p {
    max-width: 42rem;
    margin: 0.65rem 0 0;
    font-size: 0.7rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.5);
  }

  .manual-contributors__header > span {
    padding-top: 0.15rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: color-mix(in srgb, var(--wiki-accent-color) 62%, transparent);
  }

  .manual-contributors__grid-wrap {
    max-height: calc(var(--manual-card-size) * 2 + var(--manual-grid-gap));
    overflow: hidden;
    transition: max-height 560ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .manual-contributors[data-list-expanded='true'] .manual-contributors__grid-wrap {
    max-height: 120rem;
  }

  .manual-contributors__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(6.25rem, 1fr));
    gap: var(--manual-grid-gap);
  }

  .manual-contributors__card {
    position: relative;
    display: flex;
    height: var(--manual-card-size);
    min-width: 0;
    padding: 0.85rem 0.65rem 0.7rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.018);
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: border-color 260ms ease, background-color 260ms ease, transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .manual-contributors__card::before {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 10%, color-mix(in srgb, var(--wiki-accent-color) 14%, transparent), transparent 62%);
    content: '';
    opacity: 0;
    transition: opacity 260ms ease;
  }

  .manual-contributors__card::after {
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    content: '';
    pointer-events: none;
    animation: manual-contributor-hint 3.8s ease-in-out 1.2s 2;
  }

  @keyframes manual-contributor-hint {
    0%, 100% { border-color: transparent; opacity: 0; }
    38% { border-color: color-mix(in srgb, var(--wiki-accent-color) 46%, transparent); opacity: 1; }
  }

  .manual-contributors__card:hover,
  .manual-contributors__card:focus-visible,
  .manual-contributors__card[aria-expanded='true'] {
    border-color: color-mix(in srgb, var(--wiki-accent-color) 46%, rgba(255, 255, 255, 0.16));
    background: color-mix(in srgb, var(--wiki-accent-color) 6%, rgba(255, 255, 255, 0.02));
    outline: none;
    transform: translateY(-2px);
  }

  .manual-contributors__card:hover::before,
  .manual-contributors__card:focus-visible::before,
  .manual-contributors__card[aria-expanded='true']::before {
    opacity: 1;
  }

  .manual-contributors__avatar,
  .manual-contributors__avatar > img,
  .manual-contributors__avatar > span,
  .manual-contributors__detail-avatar,
  .manual-contributors__detail-avatar > img,
  .manual-contributors__detail-avatar > span {
    display: grid;
    place-items: center;
  }

  .manual-contributors__avatar {
    position: relative;
    width: 3.65rem;
    height: 3.65rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--wiki-accent-color) 34%, rgba(255, 255, 255, 0.12));
    transition: border-color 260ms ease, transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .manual-contributors__card:hover .manual-contributors__avatar,
  .manual-contributors__card:focus-visible .manual-contributors__avatar,
  .manual-contributors__card[aria-expanded='true'] .manual-contributors__avatar {
    border-color: color-mix(in srgb, var(--wiki-accent-color) 64%, white 8%);
    transform: scale(1.045);
  }

  .manual-contributors__avatar > img,
  .manual-contributors__avatar > span {
    width: 100%;
    height: 100%;
  }

  .manual-contributors__avatar img,
  .manual-contributors__detail-avatar img {
    object-fit: cover;
  }

  .manual-contributors__avatar > span,
  .manual-contributors__detail-avatar > span {
    font-family: var(--font-mono);
    color: rgba(255, 255, 255, 0.68);
  }

  .manual-contributors__avatar > span {
    font-size: 0.66rem;
  }

  .manual-contributors__card-copy {
    position: relative;
    display: grid;
    min-width: 0;
    width: 100%;
    gap: 0.18rem;
    text-align: center;
  }

  .manual-contributors__card-copy strong,
  .manual-contributors__card-copy small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .manual-contributors__card-copy strong {
    font-family: var(--font-serif);
    font-size: 0.76rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.88);
  }

  .manual-contributors__card-copy small {
    font-family: var(--font-mono);
    font-size: 0.46rem;
    letter-spacing: 0.07em;
    color: color-mix(in srgb, var(--wiki-accent-color) 62%, rgba(255, 255, 255, 0.34));
  }

  .manual-contributors__card-mark {
    position: absolute;
    top: 0.72rem;
    right: 0.72rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.28);
    transition: color 240ms ease, transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .manual-contributors__card[aria-expanded='true'] .manual-contributors__card-mark {
    color: color-mix(in srgb, var(--wiki-accent-color) 82%, white 12%);
    transform: rotate(45deg) scale(1.08);
  }

  .manual-contributors__toggle {
    display: none;
    gap: 0.55rem;
    margin: 0.85rem auto 0;
    padding: 0.35rem 0.65rem;
    align-items: center;
    border: 0;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
    cursor: pointer;
  }

  .manual-contributors[data-has-overflow='true'] .manual-contributors__toggle {
    display: flex;
  }

  .manual-contributors__toggle i {
    font-style: normal;
    transition: transform 320ms ease;
  }

  .manual-contributors[data-list-expanded='true'] .manual-contributors__toggle i {
    transform: rotate(180deg);
  }

  .manual-contributors__drawer {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 520ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
  }

  .manual-contributors[data-detail-open='true'] .manual-contributors__drawer {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .manual-contributors__drawer-clip {
    min-height: 0;
    overflow: hidden;
  }

  .manual-contributors__drawer-surface {
    position: relative;
    margin-top: 0.85rem;
    padding: clamp(1.15rem, 3vw, 1.75rem);
    border: 1px solid color-mix(in srgb, var(--wiki-accent-color) 24%, rgba(255, 255, 255, 0.08));
    background: linear-gradient(135deg, color-mix(in srgb, var(--wiki-accent-color) 5%, rgba(255, 255, 255, 0.018)), rgba(255, 255, 255, 0.008));
  }

  .manual-contributors__drawer-close {
    position: absolute;
    z-index: 1;
    top: 0.65rem;
    right: 0.8rem;
    padding: 0.25rem;
    border: 0;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.35);
    cursor: pointer;
  }

  .manual-contributors__drawer-close:hover,
  .manual-contributors__drawer-close:focus-visible {
    color: white;
    outline: none;
  }

  .manual-contributors__detail {
    display: grid;
    grid-template-columns: minmax(11rem, 0.7fr) minmax(15rem, 1.2fr) minmax(14rem, 1fr);
    gap: clamp(1.25rem, 4vw, 3.25rem);
    align-items: start;
    animation: manual-contributor-detail-in 420ms 90ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .manual-contributors__detail[hidden] {
    display: none;
  }

  @keyframes manual-contributor-detail-in {
    from { opacity: 0; transform: translateY(0.45rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  .manual-contributors__identity {
    display: grid;
    grid-template-columns: 3.5rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
  }

  .manual-contributors__detail-avatar,
  .manual-contributors__detail-avatar > img,
  .manual-contributors__detail-avatar > span {
    width: 3.5rem;
    height: 3.5rem;
  }

  .manual-contributors__detail-avatar {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--wiki-accent-color) 38%, rgba(255, 255, 255, 0.12));
  }

  .manual-contributors__detail-avatar > span {
    font-size: 0.68rem;
  }

  .manual-contributors__identity p {
    margin: 0 0 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--wiki-accent-color) 72%, white 12%);
  }

  .manual-contributors__identity h4 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.92);
  }

  .manual-contributors__bio > p {
    margin: 0;
    font-size: 0.7rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.54);
  }

  .manual-contributors__contacts {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.55rem 0.85rem;
    margin-top: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.56rem;
  }

  .manual-contributors__contacts > span {
    color: rgba(255, 255, 255, 0.28);
  }

  .manual-contributors__contacts > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.8rem;
  }

  .manual-contributors__contacts a,
  .manual-contributors__contacts strong {
    display: inline-flex;
    gap: 0.3rem;
    color: rgba(255, 255, 255, 0.72);
    font-weight: 400;
    text-decoration: none;
  }

  .manual-contributors__contacts a:hover,
  .manual-contributors__contacts a:focus-visible {
    color: white;
  }

  .manual-contributors__detail blockquote {
    margin: 0;
    padding-left: clamp(1rem, 3vw, 1.6rem);
    border-left: 1px solid color-mix(in srgb, var(--wiki-accent-color) 32%, rgba(255, 255, 255, 0.08));
  }

  .manual-contributors__detail blockquote span {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
  }

  .manual-contributors__detail blockquote p {
    margin: 0.55rem 0 0;
    font-family: var(--font-serif);
    font-size: 0.82rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.74);
  }

  .manual-contributors__empty {
    margin: 0;
    padding: 1.3rem 0 1.7rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1.7;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.38);
  }

  @media (max-width: 760px) {
    .manual-contributors {
      --manual-card-size: 6.6rem;
      --manual-grid-gap: 0.5rem;
    }

    .manual-contributors__header {
      gap: 1rem;
    }

    .manual-contributors__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .manual-contributors__detail {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .manual-contributors__detail blockquote {
      padding: 0.85rem 0 0;
      border-top: 1px solid color-mix(in srgb, var(--wiki-accent-color) 24%, rgba(255, 255, 255, 0.08));
      border-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .manual-contributors__grid-wrap,
    .manual-contributors__drawer,
    .manual-contributors__card,
    .manual-contributors__card-mark {
      transition-duration: 0.01ms;
    }

    .manual-contributors__detail {
      animation: none;
    }

    .manual-contributors__card::after {
      animation: none;
    }
  }
</style>
