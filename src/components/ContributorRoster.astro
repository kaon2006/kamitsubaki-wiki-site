---
interface Props {
  mode: 'summary' | 'entry';
  locale?: 'zh' | 'ja' | 'en' | string;
  collection?: string;
  entryId?: string;
}

const { mode, locale = 'zh', collection = '', entryId = '' } = Astro.props as Props;
const apiBase = import.meta.env.PUBLIC_AI_OBSERVER_API_BASE || 'https://kamitsubaki-ai-observer.linkth1rstyg.workers.dev';
const copy = {
  zh: {
    kicker: mode === 'entry' ? '条目维护记录' : '全站维护记录',
    title: mode === 'entry' ? '条目贡献名单' : '贡献名单',
    subtitle: mode === 'entry' ? '最近维护与累计编辑记录' : '全站最近贡献与累计贡献榜',
    loading: '读取贡献记录中',
    empty: '贡献记录等待同步',
    topTitle: '累计贡献',
    recentTitle: '最近贡献',
    contributors: '贡献者',
    contributions: '贡献',
    entries: '条目',
    commit: 'Commit',
    unknownSummary: '更新条目内容',
  },
  ja: {
    kicker: mode === 'entry' ? '記事メンテナンス記録' : 'サイトメンテナンス記録',
    title: mode === 'entry' ? '記事の貢献者' : '貢献者一覧',
    subtitle: mode === 'entry' ? '最近の更新と累積編集記録' : 'サイト全体の最近の貢献と累積ランキング',
    loading: '貢献記録を読み込み中',
    empty: '貢献記録は同期待ちです',
    topTitle: '累積貢献',
    recentTitle: '最近の貢献',
    contributors: '貢献者',
    contributions: '貢献',
    entries: '記事',
    commit: 'Commit',
    unknownSummary: '記事内容を更新',
  },
  en: {
    kicker: mode === 'entry' ? 'Entry Maintenance Record' : 'Site Maintenance Record',
    title: mode === 'entry' ? 'Entry Contributors' : 'Contributor Roster',
    subtitle: mode === 'entry' ? 'Recent maintenance and cumulative edits' : 'Recent site contributions and all-time contributors',
    loading: 'Loading contribution records',
    empty: 'Contribution records are waiting for sync',
    topTitle: 'All-Time',
    recentTitle: 'Recent',
    contributors: 'Contributors',
    contributions: 'Contributions',
    entries: 'Entries',
    commit: 'Commit',
    unknownSummary: 'Updated entry content',
  },
}[locale as 'zh' | 'ja' | 'en'] ?? {
  kicker: 'Maintenance Record',
  title: 'Contributor Roster',
  subtitle: 'Recent and cumulative contribution records',
  loading: 'Loading contribution records',
  empty: 'Contribution records are waiting for sync',
  topTitle: 'All-Time',
  recentTitle: 'Recent',
  contributors: 'Contributors',
  contributions: 'Contributions',
  entries: 'Entries',
  commit: 'Commit',
  unknownSummary: 'Updated entry content',
};
---

<section
  class:list={['contributor-roster', mode === 'summary' ? 'contributor-roster--summary' : 'contributor-roster--entry']}
  data-contributor-roster
  data-mode={mode}
  data-api-base={apiBase}
  data-locale={locale}
  data-collection={collection}
  data-entry-id={entryId}
  data-copy={JSON.stringify(copy)}
>
  <header class="contributor-roster__header">
    <div>
      <p class="contributor-roster__kicker">{copy.kicker}</p>
      <h2>{copy.title}</h2>
    </div>
    <p>{copy.subtitle}</p>
  </header>

  <div class="contributor-roster__state" data-contributor-state>{copy.loading}</div>
  <div class="contributor-roster__content" data-contributor-content hidden></div>
</section>

<script>
  import '../scripts/contributorRoster.js';
</script>
