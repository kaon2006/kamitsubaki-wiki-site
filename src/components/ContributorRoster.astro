---
interface Props {
  mode: 'summary' | 'entry';
  locale?: 'zh' | 'ja' | 'en' | string;
  collection?: string;
  entryId?: string;
}

const { mode, locale = 'zh', collection = '', entryId = '' } = Astro.props as Props;
const apiBase = import.meta.env.PUBLIC_AI_OBSERVER_API_BASE || 'https://kamitsubaki-ai-observer.linkth1rstyg.workers.dev';
const guideHref = `/${locale}/contribute/edit`;
const targetPath = collection === 'artists' && entryId ? `src/content/artists/${entryId}/${locale}.md` : '';
const editHref = targetPath ? `${guideHref}?target=${encodeURIComponent(targetPath)}` : guideHref;
const copy = {
  zh: {
    kicker: mode === 'entry' ? 'ENTRY KEEPERS' : 'COMMUNITY ARCHIVE',
    title: mode === 'entry' ? '守护这个条目的贡献者' : '一起维护这座观测站',
    subtitle: mode === 'entry' ? '每一次校正、补充和翻译，都让这份记录更完整。' : '感谢每一位留下校正、资料与翻译的观测者。这里记录共同维护，而不只是一串提交。',
    loading: '正在连接贡献记录…',
    empty: '这里还没有公开维护记录。你可以成为第一位贡献者。',
    error: '贡献记录暂时无法读取，请稍后重试。',
    retry: '重新读取',
    topTitle: '贡献者荣誉墙',
    recentTitle: '最近维护',
    contributors: '贡献者',
    contributions: '次公开维护',
    entries: '个条目',
    rankLabel: '荣誉序号',
    guideAction: '查看贡献指南',
    syntaxAction: '语法属性指南',
    joinAction: mode === 'entry' ? '维护这个条目' : '加入贡献者',
    commit: '查看修改',
    unknownSummary: '完善条目资料',
    maintainedEntry: '维护了',
    localeLabels: { zh: '中文', ja: '日本語', en: 'English' },
  },
  ja: {
    kicker: mode === 'entry' ? 'ENTRY KEEPERS' : 'COMMUNITY ARCHIVE',
    title: mode === 'entry' ? 'この記事を守る貢献者' : 'この観測記録を一緒に育てる',
    subtitle: mode === 'entry' ? '修正、追記、翻訳の一つひとつが記録をより確かなものにします。' : '修正、資料、翻訳を残してくれたすべての観測者に感謝します。',
    loading: '貢献記録に接続しています…',
    empty: '公開メンテナンス記録はまだありません。最初の貢献者になれます。',
    error: '貢献記録を読み込めませんでした。もう一度お試しください。',
    retry: '再読み込み',
    topTitle: '貢献者オナーウォール',
    recentTitle: '最近のメンテナンス',
    contributors: '貢献者',
    contributions: '回の公開メンテナンス',
    entries: '件の記事',
    rankLabel: 'オナー番号',
    guideAction: '貢献ガイドを見る',
    syntaxAction: '構文属性ガイド',
    joinAction: mode === 'entry' ? 'この記事を編集する' : '貢献に参加する',
    commit: '変更を見る',
    unknownSummary: '記事資料を更新',
    maintainedEntry: 'メンテナンス',
    localeLabels: { zh: '中文', ja: '日本語', en: 'English' },
  },
  en: {
    kicker: mode === 'entry' ? 'ENTRY KEEPERS' : 'COMMUNITY ARCHIVE',
    title: mode === 'entry' ? 'Contributors keeping this entry accurate' : 'Build this fan archive together',
    subtitle: mode === 'entry' ? 'Every correction, source, and translation makes this record stronger.' : 'Thank you to every observer who has shared corrections, sources, and translations.',
    loading: 'Connecting to contribution records…',
    empty: 'No public maintenance record yet. You can be the first contributor.',
    error: 'Contribution records are temporarily unavailable. Please try again.',
    retry: 'Try again',
    topTitle: 'Contributor honor wall',
    recentTitle: 'Recent maintenance',
    contributors: 'Contributors',
    contributions: 'public updates',
    entries: 'entries',
    rankLabel: 'Honor number',
    guideAction: 'Read the contribution guide',
    syntaxAction: 'Read the syntax guide',
    joinAction: mode === 'entry' ? 'Improve this entry' : 'Join the contributors',
    commit: 'View change',
    unknownSummary: 'Improved entry information',
    maintainedEntry: 'Maintained',
    localeLabels: { zh: '中文', ja: '日本語', en: 'English' },
  },
}[locale as 'zh' | 'ja' | 'en'] ?? {
  kicker: 'COMMUNITY ARCHIVE',
  title: 'Build this fan archive together',
  subtitle: 'Thank you to every observer helping keep these records accurate.',
  loading: 'Connecting to contribution records…',
  empty: 'No public maintenance record yet. You can be the first contributor.',
  error: 'Contribution records are temporarily unavailable. Please try again.',
  retry: 'Try again',
  topTitle: 'Contributor honor wall',
  recentTitle: 'Recent maintenance',
  contributors: 'Contributors',
  contributions: 'public updates',
  entries: 'entries',
  rankLabel: 'Honor number',
  guideAction: 'Read the contribution guide',
  syntaxAction: 'Syntax guide',
  joinAction: 'Join the contributors',
  commit: 'View change',
  unknownSummary: 'Improved entry information',
  maintainedEntry: 'Maintained',
  localeLabels: { zh: '中文', ja: '日本語', en: 'English' },
};
---

<section
  class:list={['contributor-roster', 'reveal-up', mode === 'summary' ? 'contributor-roster--summary' : 'contributor-roster--entry']}
  data-contributor-roster
  data-mode={mode}
  data-api-base={apiBase}
  data-locale={locale}
  data-collection={collection}
  data-entry-id={entryId}
  data-guide-href={guideHref}
  data-edit-href={editHref}
  data-copy={JSON.stringify(copy)}
>
  <header class="contributor-roster__header">
    <div>
      <p class="contributor-roster__kicker">{copy.kicker}</p>
      <h2>{copy.title}</h2>
    </div>
    <p>{copy.subtitle}</p>
  </header>

  <div class="contributor-roster__state" data-contributor-state>{copy.loading}</div>
  <div class="contributor-roster__content" data-contributor-content hidden></div>
</section>

<script>
  import '../scripts/contributorRoster.js';
</script>
