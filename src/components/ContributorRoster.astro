const syntaxHref = `/${locale}/contribute/syntax`;
const ownerLogin = import.meta.env.PUBLIC_SITE_OWNER_GITHUB || 'LinkTh1rsty';
const editableCollections = new Set(['artists', 'albums', 'songs', 'projects', 'logs']);
const targetPath = editableCollections.has(collection) && entryId ? `src/content/${collection}/${entryId}/${locale}.md` : '';
const editHref = targetPath ? `${guideHref}?target=${encodeURIComponent(targetPath)}` : guideHref;
